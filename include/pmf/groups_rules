################################################################################
# Rules
################################################################################

#------------------------------------------------------------------------------#
# Build Targets
#------------------------------------------------------------------------------#

.PHONY: all-groups
all-groups: | silent
	$(call target_end)

#------------------------------------------------------------------------------#
# Clean Targets
#------------------------------------------------------------------------------#

.PHONY: clean-groups
clean-groups: | silent
	$(call target_end)

#------------------------------------------------------------------------------#
# Install / Uninstall Targets
#------------------------------------------------------------------------------#

.PHONY: install-groups
install-groups: | silent
	$(call target_end)

.PHONY: uninstall-groups
uninstall-groups: | silent
	$(call target_end)

#------------------------------------------------------------------------------#
# Information Targets
#------------------------------------------------------------------------------#

.PHONY: info-groups
info-groups: | silent
	$(call heading1, Groups)
	$(call list_variables,$(groups_control_variables),$(true), control)
	$(call list_variables,$(groups_config_variables),$(false), variables)
	$(foreach x, \
		design \
		library \
		groups \
		groups_release_add \
		groups_backup_add \
		groups_project_add \
	,$(call enumerate_variable,$x,$(false),$(false)))

################################################################################
# eof
################################################################################
